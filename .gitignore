# Local environment — personal settings, never commit
docker-compose.local.yml
docker-compose.local.dev.yml

# Claude Code local settings (may contain personal paths/permissions)
.claude/settings.local.json

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
frontend/dist/
backend/dist/

# Generated map tiles (sliced from frontend/public/img/map_16k.jpg at Docker build time)
frontend/public/tiles/

# One-time tile download cache (used by build_map_tiles.py)
scripts/_scim_tile_cache/

# WIP experimental WebP/z7 tile builder — not yet wired into the build
scripts/build_map_tiles_webp.py
frontend/public/tiles_webp/

# Data-generation pipeline local artifacts (the scripts are tracked; these aren't)
scripts/datagen/__pycache__/
scripts/datagen/.venv/

# Env files
.env
.env.local

# Save files
data/*.sav

# OS / editor
.DS_Store
Thumbs.db
*.log

# Claude Code project instructions (personal/local)
CLAUDE.md

# Local planning notes (not synced to remote)
PLANNING.md
